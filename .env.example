POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=intellisys
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg2://postgres:password@127.0.0.1:5432/intellisys
CORS_ORIGINS=http://localhost:4200
OPENAI_API_KEY=
N8N_PORT=5678
AUTOMATION_WEBHOOK_SECRET=change-me-in-production
# Optional: GitHub PAT for private repos (server-side clone). Public repos work without it.
GITHUB_TOKEN=
# Optional: absolute path for cloned repos; default is backend/data/workspaces
WORKSPACE_BASE=
N8N_HOST=0.0.0.0
# n8n SSRF: allow local/dev calls (e.g. IntelliSys on host at :8000). Comma-separated; see README.
# N8N_SSRF_ALLOWED_IP_RANGES=127.0.0.0/8,::1/128
# N8N_SSRF_ALLOWED_HOSTNAMES=host.docker.internal,localhost

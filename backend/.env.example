# Copy to .env and fill in. Never commit .env to git.
DATABASE_URL=postgresql+psycopg2://postgres:password@127.0.0.1:5432/intellisys
CORS_ORIGINS=http://localhost:4200,http://127.0.0.1:4200
JWT_SECRET=change-me-in-production

# OpenAI — rotate your key in the platform if it was ever exposed; store only in env/secret manager.
OPENAI_API_KEY=
# When false, do not run AI issue generation after scan (heuristics only if enabled).
AI_ISSUES_ENABLED=true
# When false, skip dead_api/slow_api heuristics; AI-only (falls back to heuristics on AI error if true).
USE_HEURISTIC_ISSUES=true
AI_ISSUES_MODEL=gpt-4o-mini
AI_MAX_FILE_PATHS=200

# Private GitHub clone (server-side PAT only).
GITHUB_TOKEN=

AUTOMATION_WEBHOOK_SECRET=change-me-in-production
WORKSPACE_BASE=
